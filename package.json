{
  "name": "original-browser-platformer",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@10.33.3",
  "type": "module",
  "scripts": {
    "dev": "node scripts/ensure-smb-dev-cache.mjs && vite --host 127.0.0.1 --port 5177 --strictPort",
    "build": "pnpm run typecheck && vite build",
    "build:release-content": "node scripts/build-release-content.mjs",
    "build:release": "pnpm run build:release-content && pnpm run typecheck && VITE_STATIC_CONTENT=1 vite build",
    "preview": "vite preview --host 127.0.0.1",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "dead-code": "knip",
    "copy-paste": "jscpd .",
    "acquire:smb": "node scripts/acquire-smb-sources.mjs",
    "extract:smb-rom": "node scripts/extract-smb-rom-assets.mjs",
    "prepare:smb": "node scripts/prepare-smb.mjs",
    "capture:smb-frames": "node scripts/capture-smb-reference-frames.mjs",
    "verify:smb-frames": "node scripts/verify-smb-frames.mjs",
    "content-sets": "node scripts/content-sets.mjs",
    "download:user-level": "node scripts/download-user-level.mjs",
    "prepare:browser-demo-manifest": "node scripts/prepare-browser-demo-manifest.mjs",
    "prepare:vglc-smb-asset-fragment": "node scripts/prepare-vglc-smb-asset-fragment.mjs",
    "prepare:vglc-smb-browser-demo": "node scripts/prepare-vglc-smb-browser-demo.mjs",
    "prepare:vglc-smb-research": "node scripts/prepare-vglc-smb-research.mjs",
    "compare:images": "node scripts/compare-png-images.mjs",
    "research:user-levels": "node scripts/run-user-level-research.mjs",
    "audit:vulnerabilities": "node scripts/check-vulnerability-policy.mjs",
    "typecheck": "tsc --build --pretty false",
    "test": "vitest run",
    "test:browser": "pnpm run build && env -u NO_COLOR playwright test",
    "check": "pnpm run check:dependency-policy && pnpm run check:repository-content && pnpm run check:transitive-licenses && pnpm run audit:vulnerabilities && pnpm run format:check && pnpm run lint && pnpm run dead-code && pnpm run copy-paste && pnpm run typecheck && pnpm run test && pnpm run build",
    "check:dependency-policy": "node scripts/check-dependency-policy.mjs",
    "check:repository-content": "node scripts/check-repository-content-policy.mjs",
    "check:transitive-licenses": "node scripts/check-transitive-license-policy.mjs",
    "build:parody-asset-set": "node scripts/build-parody-asset-set.mjs",
    "build:rom-asset-set": "node scripts/build-rom-asset-set.mjs",
    "build:official-map-set": "node scripts/build-official-map-set.mjs"
  },
  "dependencies": {
    "phaser": "4.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.0",
    "@types/node": "26.0.0",
    "eslint": "10.5.0",
    "jscpd": "5.0.11",
    "jsnes": "2.1.0",
    "knip": "6.18.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
